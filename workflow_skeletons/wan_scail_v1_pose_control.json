{
  "schema": "scail_pose2.workflow_skeleton.v1",
  "title": "Wan SCAIL v1 Pose Control Skeleton",
  "execution": "static_only",
  "live_generation": "deferred",
  "nodes": [
    {
      "id": "nlf_render",
      "class_type": "RenderNLFPoses",
      "role": "pose_image_source",
      "required_inputs": {
        "nlf_poses": "NLFPRED",
        "render_width": "INT",
        "render_height": "INT"
      },
      "optional_inputs": {
        "bboxes": "BBOX",
        "pose_video_mask": "IMAGE"
      },
      "geometry_contract": {
        "bboxes_source": "NLFPredictPoses.bboxes",
        "render_width_height_policy": "render on render_width/render_height and emit half-size IMAGE/MASK",
        "pose_video_mask_priority": "valid pose_video_mask alignment is preferred; invalid masks can fall back to bbox repair",
        "multi_person_identity_composition": "semantic identity colors render and align each selected NLF person separately before compositing"
      },
      "outputs": {
        "image": "IMAGE",
        "mask": "MASK"
      }
    },
    {
      "id": "workflow_inputs",
      "class_type": "ExternalWorkflowInputs",
      "role": "user_supplied_reference_image_and_dimensions",
      "outputs": {
        "ref_image": "IMAGE",
        "clip_ref_image": "IMAGE",
        "width": "INT",
        "height": "INT",
        "num_frames": "INT"
      }
    },
    {
      "id": "wan_empty_embeds",
      "class_type": "WanVideoEmptyEmbeds",
      "role": "wrapper_base_embeds"
    },
    {
      "id": "wan_clip_vision",
      "class_type": "WanVideoClipVisionEncode",
      "role": "optional_clip_reference"
    },
    {
      "id": "wan_scail_reference",
      "class_type": "WanVideoAddSCAILReferenceEmbeds",
      "role": "wrapper_reference_conditioning"
    },
    {
      "id": "wan_scail_pose",
      "class_type": "WanVideoAddSCAILPoseEmbeds",
      "role": "wrapper_pose_conditioning"
    },
    {
      "id": "wan_sampler",
      "class_type": "WanVideoSamplerv2",
      "role": "wrapper_sampler"
    }
  ],
  "links": [
    {
      "from": ["workflow_inputs", "width"],
      "to": ["wan_empty_embeds", "width"],
      "type": "INT"
    },
    {
      "from": ["workflow_inputs", "height"],
      "to": ["wan_empty_embeds", "height"],
      "type": "INT"
    },
    {
      "from": ["workflow_inputs", "num_frames"],
      "to": ["wan_empty_embeds", "num_frames"],
      "type": "INT"
    },
    {
      "from": ["workflow_inputs", "ref_image"],
      "to": ["wan_scail_reference", "ref_image"],
      "type": "IMAGE"
    },
    {
      "from": ["workflow_inputs", "clip_ref_image"],
      "to": ["wan_clip_vision", "image_1"],
      "type": "IMAGE",
      "optional": true
    },
    {
      "from": ["wan_empty_embeds", "WANVIDIMAGE_EMBEDS"],
      "to": ["wan_scail_reference", "embeds"],
      "type": "WANVIDIMAGE_EMBEDS"
    },
    {
      "from": ["wan_scail_reference", "WANVIDIMAGE_EMBEDS"],
      "to": ["wan_scail_pose", "embeds"],
      "type": "WANVIDIMAGE_EMBEDS"
    },
    {
      "from": ["nlf_render", "image"],
      "to": ["wan_scail_pose", "pose_images"],
      "type": "IMAGE"
    },
    {
      "from": ["wan_scail_pose", "WANVIDIMAGE_EMBEDS"],
      "to": ["wan_sampler", "image_embeds"],
      "type": "WANVIDIMAGE_EMBEDS"
    }
  ],
  "warnings": [
    "This skeleton targets the current WanVideoWrapper SCAIL v1-style reference and pose image path.",
    "It wires directly to WanVideoWrapper v1 SCAIL nodes; SCAIL-Pose2's SCAIL-2 adapter provides the explicit-degradation fallback path.",
    "It does not represent SCAIL-2 RGB semantic masks, replacement mode, or 28-channel mask latents."
  ]
}
