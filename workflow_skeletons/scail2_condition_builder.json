{
  "schema": "scail_pose2.workflow_skeleton.v1",
  "title": "SCAIL-2 Colored Mask, Condition, And WanVideo Adapter Skeleton",
  "execution": "static_only",
  "live_generation": "deferred",
  "nodes": [
    {
      "id": "colored_masks",
      "class_type": "SCAILPose2ColoredMask",
      "role": "sam3_track_colored_mask_creation",
      "outputs": [
        { "name": "pose_video_mask", "type": "IMAGE" },
        { "name": "reference_image_mask", "type": "IMAGE" }
      ],
      "sort_modes": ["none", "left_to_right", "area"],
      "backgrounds": {
        "animation": { "driving": "black", "reference": "white" },
        "replacement": { "driving": "white", "reference": "black" }
      }
    },
    {
      "id": "scail2_condition",
      "class_type": "SCAILPose2SCAIL2Condition",
      "role": "validated_scail2_condition_builder",
      "output_type": "SCAIL2_CONDITION",
      "input_order": ["pose_video", "pose_video_mask", "ref_image", "ref_mask", "additional_ref_image", "additional_ref_mask"],
      "modes": ["animation", "replacement", "pose_driven"],
      "supports_additional_references": true,
      "supports_continuation_metadata": true
    },
    {
      "id": "wanvideo_scail2_adapter",
      "class_type": "SCAILPose2WanVideoSCAIL2Adapter",
      "role": "wanvideo_wrapper_scail2_payload_contract",
      "output_type": "SCAIL2_WANVIDEO_PAYLOAD",
      "v1_compat_output_type": "SCAIL_WAN_SCAIL_IMAGES",
      "v1_compat_outputs": ["ref_image", "pose_images", "clip_ref_image", "width", "height", "num_frames"],
      "degrade_to_v1_default": false,
      "allow_degradation_default": false
    }
  ],
  "required_condition_fields": [
    "mode",
    "replace_flag",
    "width",
    "height",
    "num_frames",
    "ref_mask_indices",
    "driving_mask_indices",
    "segment_len",
    "segment_overlap",
    "additional_references",
    "source_kind",
    "previous_frame_count",
    "video_frame_offset",
    "unsupported_wrapper_features"
  ],
  "wanvideo_scail2_adapter": {
    "payload_kind": "wanvideo_scail2_condition_adapter",
    "payload_version": 1,
    "payload_schema": {
      "name": "scail_pose2.wanvideo_scail2_payload",
      "version": 1,
      "native_wrapper_consumer": {
        "class_type": "WanVideoAddSCAIL2ConditionEmbeds",
        "input_type": "SCAIL2_WANVIDEO_PAYLOAD",
        "output_type": "WANVIDIMAGE_EMBEDS",
        "embeds_key": "scail2_embeds",
        "legacy_embeds_key": "scail_embeds",
        "simultaneous_legacy_and_native": "reject"
      },
      "runtime_mask_layouts": {
        "comfy_axes": ["batch", "latent_frame", "channel", "height", "width"],
        "scail2_axes": ["channel", "latent_frame", "height", "width"],
        "channel_count": 28,
        "temporal_stride": 4,
        "spatial_downsample": 8
      },
      "additional_references": {
        "requires_paired_image_and_mask": true,
        "mask_frame_count": 1
      }
    },
    "target": {
      "wrapper_family": "ComfyUI-WanVideoWrapper",
      "current_wrapper_path": "native_scail2_embeds",
      "fallback_wrapper_path": "v1_scail_embeds",
      "native_consumer_node": "WanVideoAddSCAIL2ConditionEmbeds",
      "native_embeds_key": "scail2_embeds",
      "requires_wrapper_scail2_support": true,
      "live_wrapper_supported": true
    },
    "degradation": {
      "is_full_scail2_parity": false,
      "requires_explicit_enable": true,
      "v1_outputs_when_enabled": {
        "wan_scail_images": "SCAIL_WAN_SCAIL_IMAGES",
        "ref_image": "IMAGE",
        "pose_images": "IMAGE",
        "clip_ref_image": "IMAGE",
        "width": "INT",
        "height": "INT",
        "num_frames": "INT"
      }
    }
  },
  "legacy_v1_semantic_losses": [
    "rgb_semantic_reference_masks",
    "rgb_semantic_driving_masks",
    "mask_latents_28_channel",
    "replacement_flag_rope_mode",
    "additional_reference_mask_pairs",
    "clean_history_segment_overlap",
    "mask_palette_track_metadata"
  ],
  "warnings": [
    "SCAIL2_CONDITION is a preprocessing contract, not a generation node.",
    "SCAIL2_WANVIDEO_PAYLOAD is consumed by WanVideoAddSCAIL2ConditionEmbeds in native SCAIL-2 wrapper workflows.",
    "Legacy WanVideoWrapper v1 SCAIL nodes consume v1-style reference and pose image conditioning only.",
    "Set degrade_to_v1 and allow_degradation only when accepting the documented semantic losses."
  ]
}
