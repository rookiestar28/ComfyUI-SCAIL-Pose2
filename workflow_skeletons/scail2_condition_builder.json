{
  "schema": "scail_pose2.workflow_skeleton.v1",
  "title": "SCAIL-2 Colored Mask, Condition, And WanVideo Adapter Skeleton",
  "execution": "static_only",
  "live_generation": "deferred",
  "nodes": [
    {
      "id": "colored_masks",
      "class_type": "SCAILPose2ColoredMask",
      "role": "sam3_track_colored_mask_creation",
      "outputs": [
        { "name": "pose_video_mask", "type": "IMAGE" },
        { "name": "reference_image_mask", "type": "IMAGE" }
      ],
      "sort_modes": ["none", "left_to_right", "area"],
      "backgrounds": {
        "animation": { "driving": "black", "reference": "white" },
        "replacement": { "driving": "white", "reference": "black" }
      }
    },
    {
      "id": "scail2_condition",
      "class_type": "SCAILPose2SCAIL2Condition",
      "role": "validated_scail2_condition_builder",
      "output_type": "SCAIL2_CONDITION",
      "modes": ["animation", "replacement", "pose_driven"],
      "supports_additional_references": true,
      "supports_continuation_metadata": true
    },
    {
      "id": "wanvideo_scail2_adapter",
      "class_type": "SCAILPose2WanVideoSCAIL2Adapter",
      "role": "wanvideo_wrapper_scail2_payload_contract",
      "output_type": "SCAIL2_WANVIDEO_PAYLOAD",
      "degrade_to_v1_default": false,
      "allow_degradation_default": false
    }
  ],
  "required_condition_fields": [
    "mode",
    "replace_flag",
    "width",
    "height",
    "num_frames",
    "ref_mask_indices",
    "driving_mask_indices",
    "segment_len",
    "segment_overlap",
    "additional_references",
    "source_kind",
    "previous_frame_count",
    "video_frame_offset",
    "unsupported_wrapper_features"
  ],
  "wanvideo_scail2_adapter": {
    "payload_kind": "wanvideo_scail2_condition_adapter",
    "payload_version": 1,
    "target": {
      "wrapper_family": "ComfyUI-WanVideoWrapper",
      "current_wrapper_path": "v1_scail_embeds",
      "requires_wrapper_scail2_support": true,
      "live_wrapper_supported": false
    },
    "degradation": {
      "is_full_scail2_parity": false,
      "requires_explicit_enable": true
    }
  },
  "unsupported_current_wan_scail_features": [
    "rgb_semantic_reference_masks",
    "rgb_semantic_driving_masks",
    "mask_latents_28_channel",
    "replacement_flag_rope_mode",
    "additional_reference_mask_pairs",
    "clean_history_segment_overlap",
    "mask_palette_track_metadata"
  ],
  "warnings": [
    "SCAIL2_CONDITION is a preprocessing contract, not a generation node.",
    "SCAIL2_WANVIDEO_PAYLOAD preserves SCAIL-2 semantics but is not live wrapper-side full SCAIL-2 parity.",
    "Current WanVideoWrapper SCAIL nodes consume v1-style reference and pose image conditioning."
  ]
}
